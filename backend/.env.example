# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/ecole_canadienne"

# JWT
JWT_SECRET="votre-secret-jwt-tres-long-et-aleatoire-min-64-chars"
JWT_EXPIRES_IN="7d"

# Serveur
PORT=5000
NODE_ENV=development

# CORS - URL du frontend
CORS_ORIGIN="http://localhost:3000"

# Uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# Email (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application
EMAIL_FROM="École Canadienne <no-reply@ecole-canadienne.cg>"
